<%# Dropdown Menu - Action menu
Usage: <%= render 'ui/dropdown', trigger_text: 'Actions', items: [
  { label: 'Edit', href: '/edit', icon: 'lucide:edit' },
  { label: 'Delete', action: 'delete', variant: 'danger' }
] %>
%>
<%
trigger_text ||= 'Menu'
trigger_icon ||= 'lucide:more-vertical'
items ||= []
align ||= 'right'
%>
<div class="relative" data-controller="dropdown">
  <button
    type="button"
    data-dropdown-target="trigger"
    data-action="click->dropdown#toggle"
    class="inline-flex items-center gap-2 px-4 py-2 text-sm font-sans font-semibold text-[hsla(320,50%,15%,1)] hover:bg-[hsla(320,20%,98%,1)] rounded-lg transition-colors"
  >
    <span><%= trigger_text %></span>
    <iconify-icon icon="<%= trigger_icon %>" class="text-base"></iconify-icon>
  </button>

  <div
    data-dropdown-target="menu"
    class="hidden absolute <%= align == 'right' ? 'right-0' : 'left-0' %> mt-2 w-56 bg-white border border-[hsla(320,25%,85%,1)] rounded-lg shadow-[0_8px_24px_rgba(77,0,82,0.16)] z-50"
    role="menu"
  >
    <div class="py-1">
      <% items.each do |item| %>
        <% if item[:divider] %>
          <div class="my-1 border-t border-[hsla(320,25%,85%,1)]"></div>
        <% else %>
          <%
            item_classes = item[:variant] == 'danger' ?
              'text-[#F16A6F] hover:bg-[#FFE8E9]' :
              'text-[hsla(320,50%,15%,1)] hover:bg-[hsla(320,20%,98%,1)]'
          %>
          <% if item[:href] %>
            <a href="<%= item[:href] %>" class="flex items-center gap-3 px-4 py-2 text-sm font-sans <%= item_classes %> transition-colors" role="menuitem">
              <% if item[:icon] %>
                <iconify-icon icon="<%= item[:icon] %>" class="text-base"></iconify-icon>
              <% end %>
              <%= item[:label] %>
            </a>
          <% else %>
            <button type="button" data-action="<%= item[:action] %>" class="w-full flex items-center gap-3 px-4 py-2 text-sm font-sans <%= item_classes %> transition-colors text-left" role="menuitem">
              <% if item[:icon] %>
                <iconify-icon icon="<%= item[:icon] %>" class="text-base"></iconify-icon>
              <% end %>
              <%= item[:label] %>
            </button>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

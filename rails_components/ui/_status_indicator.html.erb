<%# Status Indicator - Online/offline status
Usage: <%= render 'ui/status_indicator', status: 'online', label: 'Active now' %>
%>
<%
status ||= 'offline'
label ||= nil
size ||= 'medium'

status_colors = { 'online' => 'bg-green-500', 'offline' => 'bg-gray-400', 'busy' => 'bg-red-500', 'away' => 'bg-yellow-500' }
size_classes = { 'small' => 'w-2 h-2', 'medium' => 'w-3 h-3', 'large' => 'w-4 h-4' }
%>
<span class="inline-flex items-center gap-2">
  <span class="<%= size_classes[size] %> <%= status_colors[status] %> rounded-full flex-shrink-0" role="status" aria-label="<%= status %>"></span>
  <% if label %>
    <span class="text-sm font-sans text-[hsla(320,30%,35%,1)]"><%= label %></span>
  <% end %>
</span>

<%# Spinner - Loading indicator
Usage: <%= render 'ui/spinner', size: 'large', text: 'Loading...' %>
%>
<%
size ||= 'medium'
text ||= nil
variant ||= 'primary'

size_classes = { 'small' => 'w-4 h-4 border-2', 'medium' => 'w-8 h-8 border-3', 'large' => 'w-12 h-12 border-4' }
variant_classes = { 'primary' => 'border-[#4D0052]/30 border-t-[#4D0052]', 'white' => 'border-white/30 border-t-white' }
%>
<div class="inline-flex items-center gap-3" role="status">
  <div class="<%= size_classes[size] %> <%= variant_classes[variant] %> rounded-full animate-spin"></div>
  <% if text %>
    <span class="text-sm font-sans <%= variant == 'white' ? 'text-white' : 'text-[hsla(320,30%,35%,1)]' %>"><%= text %></span>
  <% end %>
  <span class="sr-only">Loading...</span>
</div>

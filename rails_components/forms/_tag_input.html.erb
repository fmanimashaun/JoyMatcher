<%#
  Tag Input Component - Multi-value Input with Tags
  Based on: Material Chip Input

  Usage:
    <%= render 'forms/tag_input',
      name: 'user[interests][]',
      label: 'Interests',
      tags: @user.interests
    %>

  Parameters:
    - name: String (required)
    - label: String
    - tags: Array - Existing tags
    - placeholder: String
    - max_tags: Integer - Maximum number of tags
%>

<%
  name ||= nil
  label ||= nil
  tags ||= []
  placeholder ||= 'Add tag...'
  max_tags ||= nil

  input_id = "tag-input-#{name.gsub(/[\[\]]/, '-')}"
%>

<div class="w-full" data-controller="tag-input" data-tag-input-max-value="<%= max_tags %>">
  <% if label %>
    <label class="block text-sm font-serif font-semibold text-[hsla(320,50%,15%,1)] mb-2">
      <%= label %>
    </label>
  <% end %>

  <div class="border border-[hsla(320,25%,85%,1)] rounded-lg p-2 focus-within:border-[#4D0052] focus-within:ring-2 focus-within:ring-[#4D0052]/20 transition-all">
    <div class="flex flex-wrap gap-2 mb-2" data-tag-input-target="container">
      <% tags.each do |tag| %>
        <div class="inline-flex items-center gap-1 px-3 py-1 bg-[#4D0052]/10 text-[#4D0052] rounded-full text-sm font-sans font-semibold">
          <span><%= tag %></span>
          <button
            type="button"
            data-action="click->tag-input#removeTag"
            data-value="<%= tag %>"
            class="p-0.5 hover:bg-[#4D0052]/20 rounded-full transition-colors"
            aria-label="Remove <%= tag %>"
          >
            <iconify-icon icon="lucide:x" class="text-xs"></iconify-icon>
          </button>
          <input type="hidden" name="<%= name %>" value="<%= tag %>">
        </div>
      <% end %>
    </div>

    <input
      type="text"
      data-tag-input-target="input"
      data-action="keydown->tag-input#handleKeydown"
      placeholder="<%= placeholder %>"
      class="w-full px-2 py-1 font-sans text-base text-[hsla(320,50%,15%,1)] focus:outline-none"
    />
  </div>
</div>

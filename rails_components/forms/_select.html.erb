<%#
  Select Component - Dropdown Selection
  Based on: Shopify Polaris Select, Headless UI Listbox

  Usage:
    <%= render 'forms/select',
      name: 'user[country]',
      label: 'Country',
      options: [['Nigeria', 'NG'], ['United States', 'US']],
      selected: 'NG'
    %>

  Parameters:
    - name: String (required)
    - label: String
    - options: Array of [label, value] pairs
    - selected: String - Currently selected value
    - placeholder: String - Placeholder option
    - required: Boolean
    - disabled: Boolean
    - error: String
    - help_text: String
    - icon: String - Lucide icon
%>

<%
  name ||= nil
  label ||= nil
  options ||= []
  selected ||= nil
  placeholder ||= 'Select an option'
  required ||= false
  disabled ||= false
  error ||= nil
  help_text ||= nil
  icon ||= 'lucide:chevron-down'

  input_id = "select-#{name.gsub(/[\[\]]/, '-')}"
  has_error = error.present?
  border_class = has_error ? 'border-[#F16A6F] focus:border-[#F16A6F] focus:ring-[#F16A6F]/20' : 'border-[hsla(320,25%,85%,1)] focus:border-[#4D0052] focus:ring-[#4D0052]/20'
%>

<div class="w-full">
  <% if label %>
    <label for="<%= input_id %>" class="block text-sm font-serif font-semibold text-[hsla(320,50%,15%,1)] mb-2">
      <%= label %>
      <% if required %>
        <span class="text-[#F16A6F]" aria-label="required">*</span>
      <% end %>
    </label>
  <% end %>

  <div class="relative">
    <select
      id="<%= input_id %>"
      name="<%= name %>"
      class="w-full px-4 py-3 pr-10 font-sans text-base text-[hsla(320,50%,15%,1)] bg-white border <%= border_class %> rounded-lg transition-all duration-250 focus:outline-none focus:ring-2 disabled:bg-[hsla(320,20%,98%,1)] disabled:cursor-not-allowed appearance-none"
      <%= 'required' if required %>
      <%= 'disabled' if disabled %>
    >
      <option value="" <%= 'selected' unless selected %>><%= placeholder %></option>
      <% options.each do |option_label, option_value| %>
        <option value="<%= option_value %>" <%= 'selected' if selected == option_value %>><%= option_label %></option>
      <% end %>
    </select>

    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
      <iconify-icon icon="<%= icon %>" class="text-base text-[hsla(320,30%,35%,1)]" aria-hidden="true"></iconify-icon>
    </div>
  </div>

  <% if error %>
    <p class="mt-2 text-sm text-[#F16A6F] font-sans" role="alert"><%= error %></p>
  <% end %>

  <% if help_text && !error %>
    <p class="mt-2 text-sm text-[hsla(320,30%,35%,1)] font-sans"><%= help_text %></p>
  <% end %>
</div>

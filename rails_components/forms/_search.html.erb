<%#
  Search Component
  Based on: Shopify Polaris Search

  Usage:
    <%= render 'forms/search',
      name: 'q',
      placeholder: 'Search profiles...',
      value: params[:q]
    %>

  Parameters:
    - name: String (default: 'q')
    - placeholder: String
    - value: String
    - autofocus: Boolean
    - clearable: Boolean (default: true) - Show clear button
%>

<%
  name ||= 'q'
  placeholder ||= 'Search...'
  value ||= nil
  autofocus ||= false
  clearable ||= true

  input_id = "search-#{name}"
%>

<div class="w-full" data-controller="search">
  <div class="relative">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <iconify-icon icon="lucide:search" class="text-base text-[hsla(320,30%,35%,1)]" aria-hidden="true"></iconify-icon>
    </div>

    <input
      type="search"
      id="<%= input_id %>"
      name="<%= name %>"
      value="<%= value %>"
      placeholder="<%= placeholder %>"
      <%= 'autofocus' if autofocus %>
      data-search-target="input"
      data-action="input->search#handleInput"
      class="w-full pl-10 <%= clearable && value.present? ? 'pr-10' : 'pr-4' %> py-3 font-sans text-base text-[hsla(320,50%,15%,1)] bg-white border border-[hsla(320,25%,85%,1)] rounded-lg transition-all duration-250 focus:outline-none focus:border-[#4D0052] focus:ring-2 focus:ring-[#4D0052]/20"
    />

    <% if clearable %>
      <button
        type="button"
        data-search-target="clearButton"
        data-action="click->search#clear"
        class="absolute inset-y-0 right-0 pr-3 flex items-center <%= value.present? ? '' : 'hidden' %>"
        aria-label="Clear search"
      >
        <iconify-icon icon="lucide:x-circle" class="text-base text-[hsla(320,30%,35%,1)] hover:text-[hsla(320,50%,15%,1)] transition-colors" aria-hidden="true"></iconify-icon>
      </button>
    <% end %>
  </div>
</div>

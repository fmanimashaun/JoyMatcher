<%#
  Date Picker Component
  Based on: Shopify Polaris DatePicker, HTML5 Date Input

  Usage:
    <%= render 'forms/date_picker',
      name: 'user[birthdate]',
      label: 'Date of Birth',
      required: true
    %>

  Parameters:
    - name: String (required)
    - label: String
    - value: String - Date value (YYYY-MM-DD)
    - min: String - Minimum date
    - max: String - Maximum date
    - required: Boolean
    - disabled: Boolean
    - error: String
    - help_text: String
%>

<%
  name ||= nil
  label ||= nil
  value ||= nil
  min ||= nil
  max ||= nil
  required ||= false
  disabled ||= false
  error ||= nil
  help_text ||= nil

  input_id = "date-picker-#{name.gsub(/[\[\]]/, '-')}"
  has_error = error.present?
  border_class = has_error ? 'border-[#F16A6F] focus:border-[#F16A6F] focus:ring-[#F16A6F]/20' : 'border-[hsla(320,25%,85%,1)] focus:border-[#4D0052] focus:ring-[#4D0052]/20'
%>

<div class="w-full">
  <% if label %>
    <label for="<%= input_id %>" class="block text-sm font-serif font-semibold text-[hsla(320,50%,15%,1)] mb-2">
      <%= label %>
      <% if required %>
        <span class="text-[#F16A6F]" aria-label="required">*</span>
      <% end %>
    </label>
  <% end %>

  <div class="relative">
    <input
      type="date"
      id="<%= input_id %>"
      name="<%= name %>"
      value="<%= value %>"
      <%= "min=\"#{min}\"" if min %>
      <%= "max=\"#{max}\"" if max %>
      <%= 'required' if required %>
      <%= 'disabled' if disabled %>
      class="w-full px-4 py-3 font-sans text-base text-[hsla(320,50%,15%,1)] bg-white border <%= border_class %> rounded-lg transition-all duration-250 focus:outline-none focus:ring-2 disabled:bg-[hsla(320,20%,98%,1)] disabled:cursor-not-allowed"
    />
  </div>

  <% if has_error %>
    <p class="mt-2 text-sm text-[#F16A6F] font-sans" role="alert"><%= error %></p>
  <% end %>

  <% if help_text && !has_error %>
    <p class="mt-2 text-sm text-[hsla(320,30%,35%,1)] font-sans"><%= help_text %></p>
  <% end %>
</div>

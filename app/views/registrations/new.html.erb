<% content_for :title, "Create Account — JoyMatcher" %>

<div class="min-h-screen py-12 px-4" style="background-color: hsla(320, 12%, 98%, 1);">
  <div class="w-full max-w-lg mx-auto">

    <%# Logo & Heading %>
    <div class="text-center mb-6">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-4" style="background: linear-gradient(135deg, #4D0052, #F16A6F);">
        <span class="text-white text-2xl font-bold" style="font-family: Georgia, serif;">J</span>
      </div>
      <h1 class="text-3xl font-semibold" style="color: hsla(320, 50%, 15%, 1); font-family: Georgia, serif;">Begin your journey</h1>
      <p class="mt-2 text-sm" style="color: hsla(320, 30%, 35%, 1);">Create your account to get started</p>
    </div>

    <%# Step indicator %>
    <div class="mb-6">
      <div class="flex items-center justify-between text-xs font-semibold mb-2" style="color: hsla(320, 30%, 35%, 1);">
        <span>Step 1 of 3 — Account Setup</span>
        <span style="color: #4D0052;">33%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" style="width: 33%;"></div>
      </div>
      <div class="flex justify-between text-xs mt-1" style="color: hsla(320, 20%, 55%, 1);">
        <span class="font-semibold" style="color: #4D0052;">Account</span>
        <span>Profile</span>
        <span>Preferences</span>
      </div>
    </div>

    <%# Error summary %>
    <% if @user&.errors&.any? %>
      <div class="alert alert-error mb-6" role="alert">
        <div>
          <p class="font-semibold mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside text-sm space-y-1">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="card" data-controller="signup-form">

      <%= form_with model: @user, url: registration_path, method: :post do |f| %>

        <%# Name fields %>
        <div class="grid grid-cols-2 gap-4">
          <div class="form-group">
            <%= f.label :first_name, class: "form-label required" do %>First Name<% end %>
            <%= f.text_field :first_name,
                class: "form-input #{'error' if @user&.errors[:first_name].any?}",
                placeholder: "Amara",
                autocomplete: "given-name",
                required: true %>
            <% if @user&.errors[:first_name].any? %>
              <p class="form-error"><%= @user.errors[:first_name].first %></p>
            <% end %>
          </div>
          <div class="form-group">
            <%= f.label :last_name, class: "form-label required" do %>Last Name<% end %>
            <%= f.text_field :last_name,
                class: "form-input #{'error' if @user&.errors[:last_name].any?}",
                placeholder: "Okonkwo",
                autocomplete: "family-name",
                required: true %>
            <% if @user&.errors[:last_name].any? %>
              <p class="form-error"><%= @user.errors[:last_name].first %></p>
            <% end %>
          </div>
        </div>

        <%# Email %>
        <div class="form-group mt-4">
          <%= f.label :email_address, class: "form-label required" do %>Email Address<% end %>
          <%= f.email_field :email_address,
              class: "form-input #{'error' if @user&.errors[:email_address].any?}",
              placeholder: "you@example.com",
              autocomplete: "email",
              required: true,
              data: { "signup-form-target": "email" } %>
          <% if @user&.errors[:email_address].any? %>
            <p class="form-error"><%= @user.errors[:email_address].first %></p>
          <% end %>
        </div>

        <%# Country %>
        <div class="form-group mt-4">
          <%= f.label :country_code, class: "form-label required" do %>Country<% end %>
          <%= f.select :country_code,
              [["Nigeria 🇳🇬", "NG"], ["United States 🇺🇸", "US"], ["United Kingdom 🇬🇧", "GB"],
               ["Canada 🇨🇦", "CA"], ["Ghana 🇬🇭", "GH"], ["Kenya 🇰🇪", "KE"],
               ["South Africa 🇿🇦", "ZA"], ["Other", "XX"]],
              { selected: @user&.country_code || "NG" },
              class: "form-input",
              required: true,
              data: { "signup-form-target": "country", action: "change->signup-form#updatePricing" } %>
          <p class="form-hint">Determines your display currency (₦ or $)</p>
        </div>

        <%# Password with strength indicator %>
        <div class="form-group mt-4" data-controller="password-visibility">
          <%= f.label :password, class: "form-label required" do %>Password<% end %>
          <div class="relative">
            <%= f.password_field :password,
                class: "form-input pr-12 #{'error' if @user&.errors[:password].any?}",
                placeholder: "Create a strong password",
                autocomplete: "new-password",
                required: true,
                minlength: 12,
                data: { "password-visibility-target": "input", "signup-form-target": "password",
                        action: "input->signup-form#checkStrength" } %>
            <button type="button"
              class="absolute inset-y-0 right-0 flex items-center px-4"
              style="color: hsla(320, 30%, 35%, 1);"
              data-action="click->password-visibility#toggle"
              aria-label="Toggle password visibility">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-password-visibility-target="icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <%# Password strength bar %>
          <div class="mt-2" data-signup-form-target="strengthBar" style="display: none;">
            <div class="progress-track" style="height: 4px;">
              <div data-signup-form-target="strengthFill" class="progress-fill" style="width: 0%; transition: width 300ms ease, background-color 300ms ease;"></div>
            </div>
            <p class="text-xs mt-1" data-signup-form-target="strengthLabel" style="color: hsla(320, 30%, 35%, 1);"></p>
          </div>
          <p class="form-hint">At least 12 characters</p>
        </div>

        <%# Confirm Password %>
        <div class="form-group mt-4">
          <%= f.label :password_confirmation, class: "form-label required" do %>Confirm Password<% end %>
          <%= f.password_field :password_confirmation,
              class: "form-input",
              placeholder: "Repeat your password",
              autocomplete: "new-password",
              required: true %>
        </div>

        <%# Subscription/Tier selection %>
        <div class="form-group mt-6">
          <p class="form-label mb-3">Choose Your Membership</p>
          <div class="grid grid-cols-3 gap-3" data-signup-form-target="pricingGrid">

            <%# Free %>
            <label class="relative cursor-pointer" for="subscription_free">
              <input type="radio" id="subscription_free" name="user[subscription]" value="0"
                class="sr-only peer" checked>
              <div class="p-3 rounded-xl border-2 text-center transition-all peer-checked:border-[#4D0052] peer-checked:bg-[rgba(77,0,82,0.03)]"
                style="border-color: hsla(320, 25%, 85%, 1);">
                <p class="text-xs font-semibold" style="color: hsla(320, 50%, 15%, 1);">Free</p>
                <p class="text-lg font-bold mt-1" style="color: #4D0052;" data-tier="free-ng">₦0</p>
                <p class="text-xs mt-1" style="color: hsla(320, 30%, 35%, 1);">Tier 2 access</p>
              </div>
            </label>

            <%# Premium %>
            <label class="relative cursor-pointer" for="subscription_premium">
              <input type="radio" id="subscription_premium" name="user[subscription]" value="1"
                class="sr-only peer">
              <div class="p-3 rounded-xl border-2 text-center transition-all peer-checked:border-[#4D0052] peer-checked:bg-[rgba(77,0,82,0.03)]"
                style="border-color: hsla(320, 25%, 85%, 1);">
                <span class="absolute -top-2 left-1/2 -translate-x-1/2 badge badge-gradient text-xs px-2">Popular</span>
                <p class="text-xs font-semibold" style="color: hsla(320, 50%, 15%, 1);">Premium</p>
                <p class="text-lg font-bold mt-1" style="color: #4D0052;" data-tier="premium-ng">₦18k</p>
                <p class="text-xs mt-1" style="color: hsla(320, 30%, 35%, 1);">/month · Tier 4</p>
              </div>
            </label>

            <%# VIP %>
            <label class="relative cursor-pointer" for="subscription_vip">
              <input type="radio" id="subscription_vip" name="user[subscription]" value="2"
                class="sr-only peer">
              <div class="p-3 rounded-xl border-2 text-center transition-all peer-checked:border-[#F16A6F] peer-checked:bg-[rgba(241,106,111,0.03)]"
                style="border-color: hsla(320, 25%, 85%, 1);">
                <p class="text-xs font-semibold" style="color: hsla(320, 50%, 15%, 1);">VIP</p>
                <p class="text-lg font-bold mt-1" style="color: #F16A6F;" data-tier="vip-ng">₦200k+</p>
                <p class="text-xs mt-1" style="color: hsla(320, 30%, 35%, 1);">Tier 5 + Expert</p>
              </div>
            </label>

          </div>
        </div>

        <%# Terms %>
        <div class="flex items-start gap-3 mt-6 p-4 rounded-xl" style="background-color: hsla(320, 20%, 98%, 1); border: 1px solid hsla(320, 25%, 85%, 1);">
          <input type="checkbox" id="terms_agree" name="terms_agree" required
            class="mt-1 w-4 h-4 rounded" style="accent-color: #4D0052;" aria-required="true">
          <label for="terms_agree" class="text-sm" style="color: hsla(320, 30%, 35%, 1);">
            I agree to JoyMatcher's
            <%= link_to "Terms of Service", "#", style: "color: #4D0052; font-weight: 600;" %> and
            <%= link_to "Privacy Policy", "#", style: "color: #4D0052; font-weight: 600;" %>.
            I confirm I am at least 18 years old and genuinely seeking marriage.
          </label>
        </div>

        <div class="mt-6">
          <%= f.submit "Create My Account",
              class: "btn btn-gradient",
              style: "width: 100%; justify-content: center;" %>
        </div>

      <% end %>

      <div class="mt-6 text-center text-sm" style="color: hsla(320, 30%, 35%, 1);">
        Already have an account?
        <%= link_to "Sign in", new_session_path,
            class: "font-semibold", style: "color: #4D0052;" %>
      </div>
    </div>

  </div>
</div>

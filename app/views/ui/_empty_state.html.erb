<%# Empty State - No results/content placeholder
Usage: <%= render 'ui/empty_state',
  icon: 'lucide:inbox',
  title: 'No messages yet',
  description: 'Send Show Interest to start conversations',
  action_text: 'Browse Profiles',
  action_href: '/discover'
%>
%>
<%
icon ||= 'lucide:inbox'
title ||= ''
description ||= nil
action_text ||= nil
action_href ||= nil
%>
<div class="text-center py-12">
  <iconify-icon icon="<%= icon %>" class="text-6xl text-[hsla(320,30%,35%,1)] mx-auto mb-4"></iconify-icon>
  <h3 class="text-lg font-serif font-semibold text-[hsla(320,50%,15%,1)] mb-2"><%= title %></h3>
  <% if description %>
    <p class="text-sm font-sans text-[hsla(320,30%,35%,1)] mb-6 max-w-sm mx-auto"><%= description %></p>
  <% end %>
  <% if action_text && action_href %>
    <%= render 'ui/button', text: action_text, href: action_href, variant: 'primary' %>
  <% end %>
</div>

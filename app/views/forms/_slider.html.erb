<%#
  Slider Component - Range Input
  Based on: Radix UI Slider, Material Slider

  Usage:
    <%= render 'forms/slider',
      name: 'user[age_preference]',
      label: 'Age Range',
      min: 25,
      max: 50,
      value: 30
    %>

  Parameters:
    - name: String (required)
    - label: String
    - min: Integer (default: 0)
    - max: Integer (default: 100)
    - value: Integer - Current value
    - step: Integer (default: 1)
    - show_value: Boolean (default: true)
    - disabled: Boolean
%>

<%
  name ||= nil
  label ||= nil
  min ||= 0
  max ||= 100
  value ||= min
  step ||= 1
  show_value ||= true
  disabled ||= false

  input_id = "slider-#{name.gsub(/[\[\]]/, '-')}"
%>

<div class="w-full" data-controller="slider">
  <div class="flex items-center justify-between mb-2">
    <% if label %>
      <label for="<%= input_id %>" class="text-sm font-serif font-semibold text-[hsla(320,50%,15%,1)]">
        <%= label %>
      </label>
    <% end %>
    <% if show_value %>
      <span data-slider-target="display" class="text-sm font-sans font-semibold text-[#4D0052]">
        <%= value %>
      </span>
    <% end %>
  </div>

  <input
    type="range"
    id="<%= input_id %>"
    name="<%= name %>"
    min="<%= min %>"
    max="<%= max %>"
    value="<%= value %>"
    step="<%= step %>"
    <%= 'disabled' if disabled %>
    data-slider-target="input"
    data-action="input->slider#update"
    class="w-full h-2 bg-[hsla(320,20%,95%,1)] rounded-full appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed
    [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-5 [&::-webkit-slider-thumb]:h-5 [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-[#4D0052] [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:shadow-[0_2px_4px_rgba(77,0,82,0.2)] [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-110
    [&::-moz-range-thumb]:w-5 [&::-moz-range-thumb]:h-5 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:bg-[#4D0052] [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:cursor-pointer [&::-moz-range-thumb]:shadow-[0_2px_4px_rgba(77,0,82,0.2)]"
  />

  <div class="flex justify-between mt-1">
    <span class="text-xs font-sans text-[hsla(320,30%,35%,1)]"><%= min %></span>
    <span class="text-xs font-sans text-[hsla(320,30%,35%,1)]"><%= max %></span>
  </div>
</div>

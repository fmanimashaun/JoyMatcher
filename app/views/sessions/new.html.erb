<% content_for :title, "Sign In — JoyMatcher" %>

<div class="min-h-screen flex items-center justify-center py-12 px-4" style="background-color: hsla(320, 12%, 98%, 1);">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-4" style="background: linear-gradient(135deg, #4D0052, #F16A6F);">
        <span class="text-white text-2xl font-bold" style="font-family: Georgia, serif;">J</span>
      </div>
      <h1 class="text-3xl font-semibold" style="color: hsla(320, 50%, 15%, 1); font-family: Georgia, serif;">Welcome back</h1>
      <p class="mt-2 text-sm" style="color: hsla(320, 30%, 35%, 1);">Sign in to your JoyMatcher account</p>
    </div>

    <% if alert.present? %>
      <div class="alert alert-error mb-6" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><%= alert %></span>
      </div>
    <% end %>

    <div class="card">
      <%= form_with url: session_path, method: :post do |f| %>

        <div class="form-group">
          <%= f.label :email_address, "Email Address", class: "form-label" %>
          <%= f.email_field :email_address,
              class: "form-input",
              placeholder: "you@example.com",
              autocomplete: "email",
              required: true,
              autofocus: true %>
        </div>

        <div class="form-group mt-4" data-controller="password-visibility">
          <div class="flex items-center justify-between mb-1">
            <%= f.label :password, "Password", class: "form-label" %>
            <%= link_to "Forgot password?", new_password_path,
                class: "text-xs font-semibold",
                style: "color: #4D0052;" %>
          </div>
          <div class="relative">
            <%= f.password_field :password,
                class: "form-input pr-12",
                placeholder: "Enter your password",
                autocomplete: "current-password",
                required: true,
                data: { "password-visibility-target": "input" } %>
            <button type="button"
              class="absolute inset-y-0 right-0 flex items-center px-4"
              style="color: hsla(320, 30%, 35%, 1);"
              data-action="click->password-visibility#toggle"
              aria-label="Toggle password visibility">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-password-visibility-target="icon"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="mt-6">
          <%= f.submit "Sign In",
              class: "btn btn-primary",
              style: "width: 100%; justify-content: center;" %>
        </div>

      <% end %>

      <div class="mt-6 text-center text-sm" style="color: hsla(320, 30%, 35%, 1);">
        Don't have an account?
        <%= link_to "Create one", new_registration_path,
            class: "font-semibold",
            style: "color: #4D0052;" %>
      </div>
    </div>

    <p class="mt-6 text-center text-xs" style="color: hsla(320, 20%, 55%, 1);">
      By signing in, you agree to our
      <%= link_to "Terms of Service", legal_terms_path, style: "color: #4D0052;" %> and
      <%= link_to "Privacy Policy", legal_privacy_path, style: "color: #4D0052;" %>.
    </p>

  </div>
</div>
